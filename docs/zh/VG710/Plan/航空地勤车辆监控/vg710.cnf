!
#system config
language Chinese
hostname VG710
ip domain-name vg.com.cn
clock timezone UTC-8
service password-encryption
!
#log config
!
#user config
username adm privilege 15 password $1$Xfx5p.9D$mDNg5U05ESjgUMtzbXGj6.
!
enable password $1$nX.NS8mb$ENySiVrzI1XNuj90CsEhN0
!
#aaa config
!
#cron config
remote-login retry 20
!
#alarm config
!
#loopback config
interface loopback 1
!
!
#ethernet interface config
!
#Ethernet sub interface config
!
#switch virtual interface config
interface vlan 1
  #IPv6 config
!
!
#ethernet config
interface gigabitethernet 1/1
  switchport mode trunk
!
interface gigabitethernet 1/2
!
interface gigabitethernet 1/3
!
interface gigabitethernet 1/4
!
!
#cellular config
cellular 1 gsm profile 1 3gnet *99***1#  ipv4 auto gprs $AES$1AECAFF97D1C43422E0186407306E5AA
cellular 1 dial interval 10
cellular 1 signal interval 120
cellular 1 network auto
cellular 1 nr5g-mode auto
cellular 1 sim 1 operator auto
cellular 1 sim 2 operator auto
cellular 1 sms mode text
cellular 1 sms interval 30
!
interface cellular 1
  dialer profile auto
  dialer profile auto secondary
  dialer timeout 120
  ipv6 address share-prefix cellular-1
  dialer activate auto
  ip address static peer 1.1.1.3
  ip address static netmask 255.255.255.255
  no ip address static local
  ip mru 1500
  ip mtu 1500
  dhcp option mtu request
  ppp ipcp dns request
  ppp keepalive 55 5
!
!
#dot11 config
interface dot11radio 1
  shutdown
  ip address dhcp
  station-role workgroup-bridge
  radio-type dot11ng
  client-mode authentication-method open
  client-mode default-route
!
interface dot11radio 2
  shutdown
  ip address dhcp
  station-role workgroup-bridge
  radio-type dot11ac
!
!
#bridge config
!
bridge 1
!
interface bridge 1
  ip address 192.168.2.1 255.255.255.0
  #IPv6 config
!
interface vlan 1
  bridge-group 1
!
!
!
#bridge mode gateway information
!
#dialer config
interface bridge 1
  pppoe-client dial-pool-number 1
!
!
#ipsec config
crypto ipsec-daemon stop
!
#l2tp config
!
#openvpn config
!
#openvpn server config
!

#dockerd config
!

#Azure IoT Edge config
!
#web config
ip web-access timeout 300
ip http server port 8000
ip https access enable
!
#telnet server config
no ip telnet server
no ip telnet access enable
!
#ssh server config
!
#dhcp-relay config
!
#dns-relay config
ip dns-relay server
!
#dhcp server config
interface bridge 1
  ip dhcp-server enable
  ip dhcp-server range 192.168.2.2 192.168.2.100
  ip dhcp-server lease 1440
!
!
#dns config
!
#ip host config
!
#ddns config
!
#snmp config

#ovdp config
!
#portal config
!
portal interface bridge 1
portal external-interface cellular 1
!
#ntp server config
  ntp master 2
  ntp server 0.pool.ntp.org
  ntp server 1.pool.ntp.org
  ntp server 2.pool.ntp.org
  ntp server 3.pool.ntp.org
