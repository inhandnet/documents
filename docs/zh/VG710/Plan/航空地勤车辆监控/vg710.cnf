#3rd-part platform config
3rd enable
3rd host smartfleet.inhandcloud.com
3rd port 1883
3rd topic-prefix CN300001/
3rd client_id VN7102202004109
3rd keepalive 60
3rd tls version tlsv1.2
3rd tls cert-verify
3rd auth admin $AES$C3CED91D3D09FB991475F71D0DA3835B6C22E2C1D492698B5CED59CB4CCDD01E
3rd adv-rpt summary basic 30 200 2 3600 7 15 0
3rd adv-rpt summary acc 0 0 0 0 0 0
!
#flexapi-tcp config
no flexapi-tcp enable
flexapi-tcp port 8000
flexapi-tcp client-id VN7102202004109
flexapi-tcp keepalive-idle 600
flexapi-tcp keepalive-interval 30
flexapi-tcp keepalive-count 5
flexapi-tcp user-timeout 3
flexapi-tcp protocol tcp
flexapi-tcp data-format json
flexapi-tcp adv-rpt summary basic 30 200 2 3600 7 15 0
flexapi-tcp adv-rpt summary acc 0 0 0 0 0 0
flexapi-tcp adv-rpt summary io 0 1 0 0
flexapi-tcp nmea-msg filter all 
flexapi-tcp nmea-msg interval 10
