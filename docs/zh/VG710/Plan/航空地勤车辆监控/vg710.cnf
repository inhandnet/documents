!
interface cellular 1
  ip access-group 192 admin
!
access-list 100 permit ip any any 
access-list 192 deny tcp any any eq 6000 
access-list 192 deny tcp any any eq 60000 
access-list 192 deny tcp any any eq 1085 
access-list 192 deny tcp any any eq 53 
access-list 192 deny udp any any eq 53 
access-list 192 deny tcp any any eq 8000 log
access-list 192 permit tcp any any eq 443 log
access-list 192 deny tcp any any eq 23 log
access-list 192 deny tcp any any eq 22 log
access-list 198 permit ip any any 
access-list 199 permit ip any any 
interface dot11radio 2
  ip nat outside
!
interface cellular 1
  ip nat outside
!
interface bridge 1
  ip nat inside
!
interface dot11radio 1
  ip nat outside
!
!
ip snat inside list 100 interface cellular 1 
ip snat inside list 199 interface dot11radio 2 
ip snat inside list 198 interface dot11radio 1 
!
