!
#cert enroll config
crypto key generate rsa general-keys modulus 1024
!
!
#dls config
dls request-timeout 60
!
#powerMgmt config
 power-management shutdown-delay 30
 power-management standby-check-interval 20
 power-management standby-voltage 90 standby-resume-voltage 105
 power-management standby-wakeup-interval 60 runtime 5
 power-management standby-interval-wakeup-voltage 60
 power-management standby-igt-shutdown-delay 15
 power-management standby-mode 1
 power-management standby-timer-wakeup 5
 power-management standby-di-shutdown-delay 10
!
!
#io config
 no io pull-up digital-input 1
 no io pull-up digital-input 2
 no io pull-up digital-input 3
 no io pull-up digital-input 4
 io output set 1 low
 no io pull-up digital-output 1
 io output set 2 low
 no io pull-up digital-output 2
 io output set 3 low
 no io pull-up digital-output 3
 io output set 4 low
 no io pull-up digital-output 4
!
!
#vagent config
report gnss 1
report motion 1
report io 10
report obdii 1
report sensor 10
!
!
#j1939 config
j1939-group basic
  enable
  interval 1
  pgn 65269 src-addr 0
  pgn 65262 src-addr 0
  pgn 65265 src-addr 0
  pgn 65270 src-addr 0
  pgn 61443 src-addr 0
  pgn 61444 src-addr 0
  pgn 61449 src-addr 62
  pgn 65276 src-addr 23
  pgn 65266 src-addr 0
  pgn 65271 src-addr 0
  pgn 64929 src-addr 81
  pgn 65272 src-addr 3
  pgn 65247 src-addr 0
  pgn 65263 src-addr 0
  pgn 65257 src-addr 0
  pgn 65248 src-addr 0
  pgn 64695 src-addr 254
  pgn 65110 src-addr 0
  pgn 65253 src-addr 0
  pgn 64765 src-addr 0
!
j1939-group listen
  enable
!
!
#obdii config
  obdii service01 interval 1
  obdii service01 pid 1
  obdii service01 pid 3
  obdii service01 pid 4
  obdii service01 pid 5
  obdii service01 pid a
  obdii service01 pid b
  obdii service01 pid c
  obdii service01 pid d
  obdii service01 pid f
